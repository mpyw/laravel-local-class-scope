<?xml version="1.0" encoding="UTF-8"?>
<phpunit backupGlobals="false"
         bootstrap="vendor/autoload.php"
         colors="true"
         processIsolation="false"
         stopOnFailure="false"
         cacheDirectory=".phpunit.cache"
         backupStaticProperties="false">

    <source>
        <include>
            <directory>./src</directory>
        </include>
        <exclude>
            <!-- PHPStan extension classes are driven by PHPStan during static
                 analysis (covered by the tests/PHPStan integration tests), not by
                 PHPUnit's line-coverage-instrumented runs, so exclude them from
                 coverage to keep the metric meaningful. -->
            <directory>./src/PHPStan</directory>
        </exclude>
    </source>

    <coverage/>

    <testsuites>
        <testsuite name="Package Test Suite">
            <directory suffix="Test.php">./tests</directory>
        </testsuite>
    </testsuites>
</phpunit>
